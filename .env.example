# .env.example — скопіюйте в .env та вкажіть свій ключ OpenAI
# Детальніше: config.py -> class Settings(BaseSettings)
# debug=true — для діагностики, false — для звичайної роботи.

# --- OpenAI ---
openai_api_key=sk-your-real-key-here

# --- Langfuse observability ---
# Create these keys in your Langfuse project settings.
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com
langfuse_prompt_label=production
langfuse_default_user_id=student_demo
langfuse_project_name=lecture-12
langfuse_project_id=cmo5s4vwa014fad07fdo9jcv6
langfuse_org_name=Test and trial.
langfuse_org_id=cmo5s3tsj010bad08i7ijqzmk
langfuse_cloud_region=EU
planner_prompt_name=planner_system
researcher_prompt_name=researcher_system
critic_prompt_name=critic_system
supervisor_prompt_name=supervisor_system

# --- Моделі агентів (можна задати окремо для кожного) ---
model_name=gpt-4o
supervisor_model=gpt-4o
planner_model=gpt-4o-mini
researcher_model=gpt-4o
critic_model=gpt-4o-mini

# --- Модель судді DeepEval (лише для тестів) ---
eval_model=gpt-4o-mini

# --- LLM control ---
llm_timeout_sec=90
llm_max_retries=2
graph_recursion_limit=40
critique_max_rounds=3
critic_max_findings_len=8000
auto_save_min_content_len=120

# --- Tool / search ---
url_fetch_timeout_sec=40
max_search_results=5
max_url_content_length=2000

# --- Output ---
output_dir=output
debug=false

# --- RAG ---
embedding_model=text-embedding-3-small
reranker_model=BAAI/bge-reranker-base
data_dir=data
index_dir=index
chunks_path=index/chunks.json

chunk_size=800
chunk_overlap=120
semantic_top_k=8
bm25_top_k=8
hybrid_top_k=10
rerank_top_n=4
hybrid_top_k=10
rerank_top_n=4